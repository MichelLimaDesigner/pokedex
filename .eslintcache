;\r\nimport { Container } from '../Home/styles';\r\n\r\nfunction TypePage(props){\r\n\r\n    const [type, setType] = useState(false);\r\n    const [pokemons, setPokemons] = useState(false);\r\n    const {id} = props.match.params;\r\n\r\n    const url = `https://pokeapi.co/api/v2/type/${id}`;\r\n\r\n    useEffect( () => {\r\n        fetch(url)\r\n        .then( res => res.json())\r\n        .then( type => {\r\n            setType(type);\r\n\r\n            let pokemonsArr = []\r\n\r\n            for(let i = 0; i < 20; i++){\r\n                pokemonsArr.push(type.pokemon[i]);\r\n            }\r\n\r\n            setPokemons(pokemonsArr);\r\n        });\r\n    }, []);\r\n\r\n    return(\r\n        <div className=\"container\">\r\n            <Container>\r\n                <h1> { type.name } </h1>\r\n                {\r\n                    pokemons ? pokemons.map( pokemon => {\r\n                        return(\r\n                            <Link to={`/pokemon/${pokemon.pokemon.name}`} key={pokemon.pokemon.name}>\r\n                                <Pokemon url={ pokemon.pokemon.url } key={pokemon.pokemon.name} />\r\n                            </Link>\r\n                        )\r\n                    }) : ''\r\n                }\r\n            </Container>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default TypePage;",["89","90"],"C:\\xampp\\htdocs\\pokedex\\src\\Pages\\PokemonPage\\index.js",[],"C:\\xampp\\htdocs\\pokedex\\src\\Pages\\Home\\index.js",[],"C:\\xampp\\htdocs\\pokedex\\src\\Pages\\PokemonPage\\styles.js",[],"C:\\xampp\\htdocs\\pokedex\\src\\Pages\\TypePage\\styles.js",[],"C:\\xampp\\htdocs\\pokedex\\src\\Pages\\Home\\styles.js",[],"C:\\xampp\\htdocs\\pokedex\\src\\Components\\Pokemon\\index.js",[],"C:\\xampp\\htdocs\\pokedex\\src\\Components\\Pokemon\\styles.js",[],"C:\\xampp\\htdocs\\pokedex\\src\\Components\\Error\\index.js",[],"C:\\xampp\\htdocs\\pokedex\\src\\Components\\ArrowBtn\\index.js",[],"C:\\xampp\\htdocs\\pokedex\\src\\Components\\Loader\